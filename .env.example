# ── Foundry Project ───────────────────────────────────────────────────────────
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_MODEL_DEPLOYMENT=
AZURE_SUBSCRIPTION_ID=
FOUNDRY_PROJECT_RESOURCE_ID=

# ── Foundry IQ Knowledge Base (Advisor Agent) ─────────────────────────────────
ADVISOR_KNOWLEDGE_BASE_NAME=
ADVISOR_SEARCH_ENDPOINT=
ADVISOR_MCP_CONNECTION=

# ── Custom MCP Server / Azure Function App (Calculator + Scheduler Agents) ────
MCP_TOOLS_ENDPOINT=
MCP_TOOLS_CONNECTION=

AI_SERVICES_NAME=
EMBEDDING_MODEL_DEPLOYMENT=

# ── Observability (OpenTelemetry → Azure Monitor) ─────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ── Cosmos DB (Persistent Conversation State) ────────────────────────────────
COSMOS_ENDPOINT=

# ── Work IQ Calendar (Calendar Agent) ────────────────────────────────────────
SCHEDULER_CALENDAR_ENDPOINT=
SCHEDULER_CALENDAR_CONNECTION=

# ── Content Understanding (Phase 14 — news ingestion pipeline) ────────────────
# CU_ENDPOINT uses the services.ai.azure.com format (NOT cognitiveservices.azure.com)
CU_ENDPOINT=
# CU_COMPLETION_DEPLOYMENT is typically the same model as FOUNDRY_MODEL_DEPLOYMENT
# but is kept separate — CU can run on a different deployment than the agent pipeline.
CU_COMPLETION_DEPLOYMENT=gpt-4.1
CU_MINI_MODEL_DEPLOYMENT=gpt-4.1-mini
CU_LARGE_EMBEDDING_DEPLOYMENT=text-embedding-3-large
CU_ANALYZER_NAME=vaMortgageNews
# CU output is written as markdown blobs; Foundry IQ auto-vectorizes from the container.
CU_NEWS_BLOB_CONTAINER=news-articles
STORAGE_ACCOUNT_ENDPOINT=
